# LiteLLM/OpenAI-compatible LLM settings. Xiaomi MiMo can be used by setting
# LLM_API_KEY and LLM_API_BASE to your MiMo-compatible endpoint.
LLM_API_KEY=
LLM_API_BASE=
LLM_MODEL=openai/mimo

# Optional: increases PubMed/E-utilities rate limits.
NCBI_API_KEY=

# Optional: Scopus Abstract Retrieval API for enriching missing abstracts/keywords.
SCOPUS_API_KEY=
